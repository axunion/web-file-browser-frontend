{
	"name": "web-file-browser-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.16.0",
			"onFail": "warn"
		},
		"packageManager": {
			"name": "pnpm",
			"version": "11.4.0",
			"onFail": "warn"
		}
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"check": "biome check src",
		"fix": "biome check --write src",
		"prepare": "lefthook install",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"swr": "^2.3.8"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.0.0",
		"@iconify/react": "^6.0.2",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"jsdom": "^26.0.0",
		"lefthook": "^2.1.8",
		"typescript": "~5.9.3",
		"vite": "^8.0.14",
		"vitest": "^3.1.0"
	}
}
