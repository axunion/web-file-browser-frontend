{
  "name": "web-file-browser-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "fix": "biome check --write .",
    "generate:icons": "node scripts/generateIconBundle.mjs",
    "prepare": "lefthook install",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/vscode-icons": "^1.2.67",
    "@iconify/react": "^6.0.2",
    "@iconify/utils": "^3.1.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.7",
    "jsdom": "^26.1.0",
    "lefthook": "^2.1.9",
    "typescript": "~5.9.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.7"
  }
}
