{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "enabledMcpjsonServers": ["context7"],
  "permissions": {
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git branch -D *)",
      "Bash(git checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git update-ref *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(git push --delete *)",
      "Bash(git push --mirror *)",
      "Bash(git tag -d *)",
      "Bash(git tag --delete *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(git worktree remove *)",
      "Bash(git submodule deinit *)",
      "Bash(gh repo delete *)",
      "Bash(gh ssh-key add *)",
      "Bash(gh auth logout *)",
      "Bash(gh secret *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -R *)",
      "Bash(rm -Rf *)",
      "Bash(rm -fR *)",
      "Bash(rm --recursive *)",
      "Bash(find * -delete)",
      "Bash(find * -exec rm *)",
      "Bash(xargs rm *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(git config *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(cargo publish *)",
      "Bash(sudo *)",
      "Bash(sudoedit *)",
      "Bash(doas *)",
      "Bash(su *)",
      "Bash(pkexec *)",
      "Bash(security export *)",
      "Bash(security find-generic-password *)",
      "Bash(security find-internet-password *)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.gnupg/*)",
      "Bash(head ~/.ssh/*)",
      "Bash(head ~/.aws/*)",
      "Bash(head ~/.gnupg/*)",
      "Bash(tail ~/.ssh/*)",
      "Bash(tail ~/.aws/*)",
      "Bash(tail ~/.gnupg/*)",
      "Bash(less ~/.ssh/*)",
      "Bash(less ~/.aws/*)",
      "Bash(less ~/.gnupg/*)",
      "Bash(more ~/.ssh/*)",
      "Bash(more ~/.aws/*)",
      "Bash(more ~/.gnupg/*)",
      "Bash(cat ~/.netrc)",
      "Bash(cat ~/.npmrc)",
      "Bash(cat ~/.pypirc)",
      "Bash(cat ~/.kube/*)",
      "Bash(cat ~/.docker/*)",
      "Bash(cat ~/.config/gcloud/*)",
      "Bash(head ~/.netrc)",
      "Bash(head ~/.npmrc)",
      "Bash(head ~/.pypirc)",
      "Bash(head ~/.kube/*)",
      "Bash(head ~/.docker/*)",
      "Bash(head ~/.config/gcloud/*)",
      "Bash(tail ~/.netrc)",
      "Bash(tail ~/.npmrc)",
      "Bash(tail ~/.pypirc)",
      "Bash(tail ~/.kube/*)",
      "Bash(tail ~/.docker/*)",
      "Bash(tail ~/.config/gcloud/*)",
      "Bash(less ~/.netrc)",
      "Bash(less ~/.npmrc)",
      "Bash(less ~/.pypirc)",
      "Bash(less ~/.kube/*)",
      "Bash(less ~/.docker/*)",
      "Bash(less ~/.config/gcloud/*)",
      "Bash(more ~/.netrc)",
      "Bash(more ~/.npmrc)",
      "Bash(more ~/.pypirc)",
      "Bash(more ~/.kube/*)",
      "Bash(more ~/.docker/*)",
      "Bash(more ~/.config/gcloud/*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gcloud/**)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Edit(~/.zshenv)",
      "Edit(~/.profile)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)",
      "Write(~/.bash_profile)",
      "Write(~/.zprofile)",
      "Write(~/.zshenv)",
      "Write(~/.profile)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/src/**)",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); pnpm exec biome check --write \"${f#$PWD/}\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(**/src/**)",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); pnpm exec biome check --write \"${f#$PWD/}\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
